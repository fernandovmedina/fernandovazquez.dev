---
import { frameworks, languages, cloudInfra } from "../data/stack";
import BallButton from "../components/BallButton.astro";
import { Icon } from "astro-icon/components";
import SectionDivider from "../components/SectionDivider.astro";

const allTech = [
  ...languages.map(t => ({ ...t, ring: 1 })),
  ...cloudInfra.map(t => ({ ...t, ring: 2 })),
  ...frameworks.map(t => ({ ...t, ring: 3 })),
];
---

<section class="w-full bg-[#0f0f0f] pb-24 md:pb-32" id="tech-orbit">
  <SectionDivider text="Tech Stack" />
  
  <div class="max-w-7xl mx-auto px-5 md:px-8 pt-16 pb-4 text-center">
    <span class="text-xs font-bold tracking-[0.2em] text-violet-400/70 uppercase" data-reveal="fade">
      — Tools & Technologies —
    </span>
    <h2 class="text-4xl md:text-5xl font-dm font-semibold text-white mt-3" data-reveal="up" data-reveal-delay="0.1">
      My Tech Stack
    </h2>
    <p class="text-base text-gray-400 mt-3 max-w-lg mx-auto" data-reveal="up" data-reveal-delay="0.2">
      Click a category to highlight the technologies I use in each domain.
    </p>
  </div>

  <!-- Desktop: orbital animation -->
  <div class="desktop-orbit hidden md:block" id="stack">
    <div class="grid md:grid-cols-5 grid-cols-1 h-full min-h-[700px]">

      <!-- Orbits -->
      <div class="hidden md:flex md:col-span-3 w-full h-full justify-center items-center relative pt-10">
        <!-- Play/pause controls -->
        <div id="play" class="absolute z-10 hidden">
          <Icon name="play-solid" class="move-btn w-50 h-50 hover:bg-[#1a0933] rounded-full" />
        </div>
        <div id="pause" class="absolute z-10">
          <Icon name="pause-solid" class="move-btn w-50 h-50 hover:bg-[#1a0933] rounded-full" />
        </div>

        <!-- Inner ring -->
        <div class="absolute w-[25rem] h-[25rem] border border-white/[0.06] rounded-full" id="orbit1">
          {languages.map((tech, i) => (
            <img
              src={`https://skillicons.dev/icons?i=${tech.icon}`}
              alt={tech.icon}
              class="orbit-icon category-icon"
              data-categories={tech.categories.join(",")}
              style={`transform: rotate(${i * (360 / languages.length)}deg) translateY(-12rem) rotate(-${i * (360 / languages.length)}deg);`}
            />
          ))}
        </div>

        <!-- Middle ring -->
        <div class="absolute w-[35rem] h-[35rem] border border-white/[0.06] rounded-full" id="orbit2">
          {cloudInfra.map((tech, i) => (
            <img
              src={`https://skillicons.dev/icons?i=${tech.icon}`}
              alt={tech.icon}
              class="orbit-icon-2 category-icon"
              data-categories={tech.categories.join(",")}
              style={`transform: rotate(${i * (360 / cloudInfra.length)}deg) translateY(-18rem) rotate(-${i * (360 / cloudInfra.length)}deg);`}
            />
          ))}
        </div>

        <!-- Outer ring -->
        <div class="absolute w-[45rem] h-[45rem] border border-white/[0.06] rounded-full" id="orbit3">
          {frameworks.map((tech, i) => (
            <img
              src={`https://skillicons.dev/icons?i=${tech.icon}`}
              alt={tech.icon}
              class="orbit-icon-3 category-icon"
              data-categories={tech.categories.join(",")}
              style={`transform: rotate(${i * (360 / frameworks.length)}deg) translateY(-23rem) rotate(-${i * (360 / frameworks.length)}deg);`}
            />
          ))}
        </div>
      </div>

      <!-- Category buttons (desktop) -->
      <div id="btns-stack" class="col-span-2 flex flex-col justify-center items-center h-full gap-2 py-12 px-4">
        <p class="text-xs font-bold tracking-[0.15em] text-gray-500 uppercase mb-4">Filter by category</p>
        <BallButton title="All" id="All" />
        <BallButton title="My Main Stack" id="My Main Stack" />
        <BallButton title="Frontend Stack" id="Frontend Stack" />
        <BallButton title="Backend Stack" id="Backend Stack" />
        <BallButton title="DevOps Stack" id="DevOps Stack" />
        <BallButton title="AI/ML Solutions" id="AI/ML Solutions" />
        <BallButton title="My OS favorites tools" id="My OS favorites tools" />
      </div>
    </div>
  </div>

  <!-- Mobile: flat grid of icons + filter -->
  <div class="mobile-tech md:hidden px-5 pb-16">
    <!-- Filter buttons -->
    <div class="mobile-filter-scroll">
      {["All", "My Main Stack", "Frontend Stack", "Backend Stack", "DevOps Stack", "AI/ML Solutions"].map(cat => (
        <button
          class="mobile-filter-btn"
          data-cat={cat}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Icon grid -->
    <div class="mobile-icon-grid" id="mobile-icon-grid">
      {allTech.map(tech => (
        <div
          class="mobile-icon-item"
          data-categories={tech.categories.join(",")}
          title={tech.icon}
        >
          <img
            src={`https://skillicons.dev/icons?i=${tech.icon}`}
            alt={tech.icon}
            class="mobile-icon-img"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* ─── Desktop orbital icons ──────────────────────── */
  .orbit-icon,
  .orbit-icon-2,
  .orbit-icon-3 {
    position: absolute;
    width: 3rem;
    height: 3rem;
    transform-origin: center;
    transition: filter 0.3s, opacity 0.3s;
    opacity: 0;
  }

  .orbit-icon   { top: 45%; left: 45%; }
  .orbit-icon-2 { top: 47%; left: 47%; }
  .orbit-icon-3 { top: 47%; left: 47%; }

  .highlighted { opacity: 1 !important; }
  .dimmed      { opacity: 0.1 !important; }

  /* ─── Mobile filter ──────────────────────────────── */
  .mobile-filter-scroll {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    margin-bottom: 1.5rem;
    scrollbar-width: none;
  }

  .mobile-filter-scroll::-webkit-scrollbar { display: none; }

  .mobile-filter-btn {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.4rem 0.85rem;
    border-radius: 999px;
    border: 1.5px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.5);
    white-space: nowrap;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
    cursor: none;
  }

  .mobile-filter-btn:hover,
  .mobile-filter-btn.active {
    border-color: #a855f7;
    color: #a855f7;
    background: rgba(168,85,247,0.08);
  }

  /* ─── Mobile icon grid ───────────────────────────── */
  .mobile-icon-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(3.5rem, 1fr));
    gap: 0.75rem;
  }

  .mobile-icon-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 0.6rem;
    border: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.03);
    transition: opacity 0.3s, border-color 0.3s;
  }

  .mobile-icon-item.mobile-hidden {
    opacity: 0.08;
  }

  .mobile-icon-item.mobile-active {
    border-color: rgba(168,85,247,0.3);
    background: rgba(168,85,247,0.06);
  }

  .mobile-icon-img {
    width: 2.5rem;
    height: 2.5rem;
    object-fit: contain;
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  let orbit1Tween: gsap.core.Tween;
  let orbit2Tween: gsap.core.Tween;
  let orbit3Tween: gsap.core.Tween;
  let isPlaying = true;

  document.addEventListener("DOMContentLoaded", () => {
    // ── Desktop orbital setup ─────────────────────────────────────────
    const desktopOrbit = document.getElementById("stack");
    if (desktopOrbit) {
      // Entrance animation (play once, no scrub so orbits stay visible)
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: "#stack",
          start: "top 70%",
          toggleActions: "play none none none",
        },
      });

      tl.from("#orbit1", { y: 60, opacity: 0, duration: 0.7, ease: "power3.out" })
        .from("#orbit2", { y: 80, opacity: 0, duration: 0.7, ease: "power3.out" }, "-=0.5")
        .from("#orbit3", { y: 100, opacity: 0, duration: 0.7, ease: "power3.out" }, "-=0.5")
        .from("#pause",  { opacity: 0, scale: 0.8, duration: 0.4, ease: "back.out(1.5)" }, "-=0.3")
        .from("#btns-stack", { x: 40, opacity: 0, duration: 0.6, ease: "power3.out" }, "-=0.6");

      // Start orbiting
      orbit1Tween = gsap.to("#orbit1", { rotate: 360,  duration: 50, repeat: -1, ease: "none" });
      orbit2Tween = gsap.to("#orbit2", { rotate: -360, duration: 75, repeat: -1, ease: "none" });
      orbit3Tween = gsap.to("#orbit3", { rotate: 360,  duration: 100, repeat: -1, ease: "none" });

      // Category filter
      const icons = document.querySelectorAll(".category-icon");
      const buttons = document.querySelectorAll<HTMLElement>(".ball-button, .category-button");

      function filterCategory(cat: string) {
        icons.forEach((icon) => {
          const cats = icon.getAttribute("data-categories") ?? "";
          if (cat === "All" || cats.includes(cat)) {
            icon.classList.add("highlighted");
            icon.classList.remove("dimmed");
          } else {
            icon.classList.remove("highlighted");
            icon.classList.add("dimmed");
          }
        });
      }

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          const cat = btn.getAttribute("data-category") ?? btn.id;
          if (!cat || cat === "toggle-spin") return;
          filterCategory(cat);
        });
      });

      // Default: show all
      filterCategory("All");

      // Play/pause
      const playBtn  = document.getElementById("play")!;
      const pauseBtn = document.getElementById("pause")!;

      pauseBtn.addEventListener("click", () => {
        orbit1Tween.pause();
        orbit2Tween.pause();
        orbit3Tween.pause();
        isPlaying = false;
        pauseBtn.classList.add("hidden");
        playBtn.classList.remove("hidden");
      });

      playBtn.addEventListener("click", () => {
        orbit1Tween.resume();
        orbit2Tween.resume();
        orbit3Tween.resume();
        isPlaying = true;
        playBtn.classList.add("hidden");
        pauseBtn.classList.remove("hidden");
      });
    }

    // ── Mobile icon grid filter ───────────────────────────────────────
    const mobileFilterBtns = document.querySelectorAll<HTMLElement>(".mobile-filter-btn");
    const mobileItems      = document.querySelectorAll<HTMLElement>(".mobile-icon-item");

    function filterMobile(cat: string) {
      mobileFilterBtns.forEach(b => b.classList.toggle("active", b.dataset.cat === cat));
      mobileItems.forEach((item) => {
        const cats = item.dataset.categories ?? "";
        if (cat === "All" || cats.includes(cat)) {
          item.classList.remove("mobile-hidden");
          item.classList.add("mobile-active");
        } else {
          item.classList.add("mobile-hidden");
          item.classList.remove("mobile-active");
        }
      });
    }

    mobileFilterBtns.forEach(btn => {
      btn.addEventListener("click", () => filterMobile(btn.dataset.cat ?? "All"));
    });

    // Default
    filterMobile("All");
  });
</script>
