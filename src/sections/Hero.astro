---
import WebGLShader from "../components/WebGLShader.astro";
import LiquidButton from "../components/LiquidButton.astro";
import GlassFilter from "../components/GlassFilter.astro";
import { Icon } from "astro-icon/components";
import { site, socials } from "../data/site";
---

<section id="top" class="relative flex min-h-screen w-full flex-col items-center justify-center overflow-hidden">
	<WebGLShader />

	<div class="relative border border-[#27272a] p-2 w-[92%] mx-auto max-w-3xl mt-16" data-reveal="up">
		<div class="relative border border-[#27272a] py-10 overflow-hidden bg-black/20 backdrop-blur-[2px]">
			<p class="text-center text-xs md:text-sm font-mono tracking-[0.3em] uppercase text-violet-300/80 mb-4">
				{site.role} · Saltillo, MX
			</p>
			<h1 class="mb-3 text-white text-center font-display font-extrabold tracking-tighter text-5xl md:text-[clamp(2rem,8vw,6rem)] leading-none">
				Fernando<br class="md:hidden" /> Vazquez
			</h1>
			<p class="text-white/60 px-6 text-center text-xs md:text-sm lg:text-lg max-w-xl mx-auto">
				Backend-focused fullstack developer crafting fast, scalable products with Go, TypeScript and the modern web.
			</p>

			<div class="my-8 flex items-center justify-center gap-1">
				<span class="relative flex h-3 w-3 items-center justify-center">
					<span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-500 opacity-75"></span>
					<span class="relative inline-flex h-2 w-2 rounded-full bg-green-500"></span>
				</span>
				<p class="text-xs text-green-500">Available for New Projects</p>
			</div>

			<div class="flex flex-col sm:flex-row items-center justify-center gap-4 px-6">
				<LiquidButton href="#contact">Let's Talk</LiquidButton>
				<a
					href={site.cv}
					download
					class="inline-flex items-center gap-2 h-12 px-8 rounded-full text-sm font-medium text-white/80 border border-white/15 hover:border-violet-400 hover:text-violet-300 transition-colors"
				>
					<Icon name="download-solid" class="w-4 h-4" />
					Download CV
				</a>
			</div>

			<div class="mt-8 flex items-center justify-center gap-5">
				{socials.map((social) => (
					<a
						href={social.href}
						target={social.href.startsWith("mailto") ? undefined : "_blank"}
						rel="noreferrer"
						aria-label={social.name}
						class="text-white/50 hover:text-violet-300 transition-colors"
					>
						<Icon name={social.icon} class="w-5 h-5" />
					</a>
				))}
			</div>
		</div>
	</div>

	<a
		href="#about"
		aria-label="Scroll down"
		class="absolute bottom-8 left-1/2 -translate-x-1/2 text-white/40 hover:text-violet-300 transition-colors animate-bounce"
	>
		<Icon name="down-solid" class="w-5 h-5" />
	</a>

	<GlassFilter />
</section>
