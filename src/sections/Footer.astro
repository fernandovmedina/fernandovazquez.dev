---
import { Icon } from "astro-icon/components";
import { site, socials, navLinks } from "../data/site";

const year = new Date().getFullYear();
---

<footer class="border-t border-white/5 bg-[#0c0c0c]">
	<div class="max-w-7xl mx-auto px-5 md:px-8 py-12 flex flex-col md:flex-row items-center justify-between gap-8">
		<div class="text-center md:text-left">
			<a href="#top" class="font-display font-bold text-2xl text-white tracking-tight">
				f-root<span class="text-violet-400">.</span>
			</a>
			<p class="text-sm text-gray-500 mt-2">
				© {year} {site.name}. Built with Astro & Tailwind CSS.
			</p>
		</div>

		<ul class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
			{navLinks.map((link) => (
				<li>
					<a href={link.href} class="text-sm text-gray-500 hover:text-white transition-colors">
						{link.label}
					</a>
				</li>
			))}
		</ul>

		<div class="flex items-center gap-5">
			{socials.map((social) => (
				<a
					href={social.href}
					target={social.href.startsWith("mailto") ? undefined : "_blank"}
					rel="noreferrer"
					aria-label={social.name}
					class="text-gray-500 hover:text-violet-300 transition-colors"
				>
					<Icon name={social.icon} class="w-5 h-5" />
				</a>
			))}
		</div>
	</div>
</footer>
