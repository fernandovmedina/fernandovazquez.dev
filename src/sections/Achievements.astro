---
import SectionHeading from "../components/SectionHeading.astro";
import { Icon } from "astro-icon/components";
import { achievements } from "../data/achievements";
---

<section id="achievements" class="w-full pb-24 md:pb-32">
	<SectionHeading
		eyebrow="Contests & Hackathons"
		title="Achievements"
		subtitle="Where I've competed, shipped under pressure, and placed."
	/>

	<div class="max-w-6xl mx-auto px-5 md:px-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
		{achievements.map((a, i) => (
			<div
				class:list={[
					"group rounded-2xl border border-white/10 bg-white/[0.03] p-6 flex flex-col gap-4",
					"hover:border-violet-400/40 hover:bg-violet-500/[0.04] transition-colors",
					i === 0 && "sm:col-span-2 lg:col-span-1",
				]}
				data-reveal="up"
				data-reveal-delay={String(Math.min(i * 0.08, 0.32))}
			>
				<div class="flex items-start justify-between gap-3">
					<span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-violet-500/10 text-violet-300 group-hover:bg-violet-500/20 transition-colors">
						<Icon name="trophy-solid" class="w-5 h-5" />
					</span>
					<span class="text-[10px] font-bold uppercase tracking-wider text-violet-300 border border-violet-400/30 rounded-full px-2.5 py-1 whitespace-nowrap">
						{a.place}
					</span>
				</div>

				<div>
					<h3 class="text-lg font-display font-semibold text-white leading-snug">{a.title}</h3>
					<p class="text-xs text-gray-500 font-medium mt-1">{a.venue}</p>
				</div>

				<p class="text-sm text-gray-400 leading-relaxed grow">{a.description}</p>

				<div class="flex flex-wrap gap-2">
					{a.tech.map((t) => (
						<span class="text-xs font-medium text-gray-400 border border-white/10 rounded-full px-3 py-1">
							{t}
						</span>
					))}
				</div>
			</div>
		))}
	</div>
</section>
