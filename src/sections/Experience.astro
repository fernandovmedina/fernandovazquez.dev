---
import SectionHeading from "../components/SectionHeading.astro";
import { experience } from "../data/experience";
---

<section id="experience" class="w-full pb-24 md:pb-32">
	<SectionHeading
		eyebrow="Where I've Worked"
		title="Experience"
		subtitle="From automating HR at a supermarket chain to running my own software studio."
	/>

	<div class="max-w-4xl mx-auto px-5 md:px-8">
		<ol class="relative border-l border-white/10 ml-3 md:ml-6 space-y-12">
			{experience.map((job) => (
				<li class="pl-8 md:pl-12 relative" data-reveal="up">
					<span
						class:list={[
							"absolute -left-[7px] top-1.5 h-3.5 w-3.5 rounded-full border-2",
							job.current
								? "bg-violet-500 border-violet-300 shadow-[0_0_12px_rgba(168,85,247,0.8)]"
								: "bg-[#0f0f0f] border-white/30",
						]}
					></span>

					<div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
						<h3 class="text-xl md:text-2xl font-display font-semibold text-white">
							{job.company}
						</h3>
						<span class="text-sm font-mono text-violet-300/80">{job.period}</span>
						{job.current && (
							<span class="text-[10px] font-bold uppercase tracking-wider text-green-400 border border-green-400/30 rounded-full px-2 py-0.5">
								Current
							</span>
						)}
					</div>
					<p class="text-sm text-gray-400 font-medium mt-1">{job.role}</p>

					<ul class="mt-4 space-y-2">
						{job.bullets.map((bullet) => (
							<li class="text-gray-300 text-sm md:text-base leading-relaxed flex gap-3">
								<span class="text-violet-400 mt-1.5 shrink-0 h-1 w-1 rounded-full bg-violet-400"></span>
								{bullet}
							</li>
						))}
					</ul>

					<div class="mt-4 flex flex-wrap gap-2">
						{job.tech.map((t) => (
							<span class="text-xs font-medium text-gray-400 border border-white/10 bg-white/[0.03] rounded-full px-3 py-1">
								{t}
							</span>
						))}
					</div>
				</li>
			))}
		</ol>
	</div>
</section>
