---
// SVG displacement filter used by LiquidButton. Include once per page.
---

<svg class="hidden" aria-hidden="true">
	<defs>
		<filter
			id="liquid-glass-filter"
			x="0%"
			y="0%"
			width="100%"
			height="100%"
			color-interpolation-filters="sRGB"
		>
			<feTurbulence
				type="fractalNoise"
				baseFrequency="0.05 0.05"
				numOctaves="1"
				seed="1"
				result="turbulence"
			></feTurbulence>
			<feGaussianBlur in="turbulence" stdDeviation="2" result="blurredNoise"></feGaussianBlur>
			<feDisplacementMap
				in="SourceGraphic"
				in2="blurredNoise"
				scale="70"
				xChannelSelector="R"
				yChannelSelector="B"
				result="displaced"
			></feDisplacementMap>
			<feGaussianBlur in="displaced" stdDeviation="4" result="finalBlur"></feGaussianBlur>
			<feComposite in="finalBlur" in2="finalBlur" operator="over"></feComposite>
		</filter>
	</defs>
</svg>
